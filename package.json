{
  "name": "quickpaste",
  "private": true,
  "license": "UNLICENSED",
  "version": "0.7.0",
  "packageManager": "npm@11.9.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "build": "npm run typecheck && vite build && npm run check:code-highlight-build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:governance": "node --test scripts/check-repository.test.mjs scripts/check-versions.test.mjs scripts/check-privacy.test.mjs scripts/check-runtime-boundaries.test.mjs scripts/check-code-highlight-build.test.mjs scripts/acceptance/acceptance.test.mjs",
    "check:versions": "node scripts/check-versions.mjs",
    "check:repository": "node scripts/check-repository.mjs",
    "check:privacy": "node scripts/check-privacy.mjs",
    "check:runtime-boundaries": "node scripts/check-runtime-boundaries.mjs",
    "check:licenses": "node scripts/check-third-party-notices.mjs",
    "check:code-highlight-build": "node scripts/check-code-highlight-build.mjs",
    "check:governance": "npm run test:governance && npm run check:versions && npm run check:repository && npm run check:privacy && npm run check:runtime-boundaries && npm run check:licenses",
    "check:frontend": "npm test && npm run build",
    "format:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "lint:rust": "cargo clippy --locked --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "test:rust": "cargo test --locked --manifest-path src-tauri/Cargo.toml --all-features",
    "check:rust": "npm run format:rust:check && npm run lint:rust && npm run test:rust",
    "check": "npm run check:governance && npm run check:frontend && npm run check:rust",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "licenses:npm": "node scripts/generate-npm-notices.mjs",
    "licenses:rust": "node scripts/generate-rust-notices.mjs",
    "licenses:native": "node scripts/generate-native-notices.mjs",
    "build:windows": "tauri build --bundles nsis --target x86_64-pc-windows-msvc",
    "tauri": "tauri"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "22.14.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": "11.9.0",
      "onFail": "error"
    }
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.2.4"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "highlight.js": "11.11.1",
    "lucide-vue-next": "^0.577.0",
    "pinyin-pro": "3.28.1",
    "vue": "^3.5.40"
  }
}
